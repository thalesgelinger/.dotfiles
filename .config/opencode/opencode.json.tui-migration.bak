{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight-transparent",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:8b": {
          "name": "Llama 3.1"
        },
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9b"
        }
      }
    }
  },
  "command": {
    "multi-phase": {
      "template": "Make this plan multi-phased",
      "description": "Breakdown a long plan into multi phased to get better results from context windo"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-b8d04c26-ace8-4049-8b66-d44b6a789c9c"
      },
      "enabled": false
    },
    "expo": {
      "type": "remote",
      "url": "https://mcp.expo.dev/mcp",
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "shortcut": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@shortcut/mcp@latest"
      ],
      "environment": {
        "SHORTCUT_API_TOKEN": "1e66e5e3-7478-489d-aed4-ad425b56d3e8"
      },
      "enabled": false
    },
    "figma": {
      "type": "remote",
      "enabled": true,
      "url": "http://127.0.0.1:3845/mcp"
    },
    "maestro": {
      "type": "local",
      "command": [
        "maestro",
        "mcp"
      ],
      "enabled": true
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/sse"
      ],
      "enabled": false
    },
    "leaf": {
      "type": "local",
      "command": [
        "bun",
        "run",
        "/Users/thalesgelinger/Projects/herbalife/leaf-design-system/mcp.ts"
      ],
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "plane": {
      "type": "local",
      "command": [
        "npx",
        "mcp-remote@latest",
        "https://mcp.plane.so/http/mcp"
      ],
      "enabled": false
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}